# ELITEA Proxy Configuration Template
# Copy this file to .env and fill in your actual values

# ================================
# REQUIRED CONFIGURATION
# ================================

# ELITEA API Authentication Token (REQUIRED)
# Get this from the ELITEA dashboard at https://next.elitea.ai
ELITEA_TOKEN=your_elitea_jwt_token_here

# ================================
# OPTIONAL CONFIGURATION
# ================================

# ELITEA API Configuration
ELITEA_BASE_URL=https://next.elitea.ai/llm/v1

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=4000
SERVER_DEBUG=false

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# File logging configuration
# Path to log file (relative to project root or absolute path)
LOG_FILE=logs/elitea-proxy.log
# Maximum size per log file in bytes (default: 10MB)
LOG_MAX_BYTES=10485760
# Number of backup log files to keep (default: 5)
LOG_BACKUP_COUNT=5

# Performance Settings
REQUEST_TIMEOUT=30
STREAM_CHUNK_SIZE=1024
TOKEN_ESTIMATION_RATIO=4

# ================================
# NOTES
# ================================

# Model Mappings:
# The proxy automatically maps these Claude models to ELITEA models:
# - claude-haiku-4-5-20251001 -> eu.anthropic.claude-sonnet-4-20250514-v1:0
# - claude-sonnet-4-5-20250929 -> eu.anthropic.claude-sonnet-4-20250514-v1:0
# - eu.anthropic.claude-sonnet-4-20250514-v1:0 -> eu.anthropic.claude-sonnet-4-20250514-v1:0

# Unsupported Parameters:
# The proxy automatically strips these parameters from requests:
# - thinking
# - anthropic_beta